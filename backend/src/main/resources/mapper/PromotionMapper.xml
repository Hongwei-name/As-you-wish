<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.shopping.mapper.PromotionMapper">
    
    <select id="selectActivePromotions" resultType="com.shopping.entity.Promotion">
        SELECT * FROM t_promotion 
        WHERE status = 1 
        AND start_time &lt;= NOW() 
        AND end_time &gt;= NOW()
    </select>
    
</mapper>
